{
    "manifest_version": 3,
    "name": "Transform Text",
    "version": "1.0.0",
    "description": "Right-click any selected text to transform it — change case, escape newlines, and more.",
    "permissions": [
        "contextMenus",
        "activeTab"
    ],
    "background": {
        "service_worker": "dist/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "dist/content.js"
            ]
        }
    ]
}